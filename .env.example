# Database
DATABASE_URL=postgresql://user:password@localhost:5432/apex_auto_trader

# JWT
JWT_SECRET=your-super-secret-key-min-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Admin Account (created on first run)
ADMIN_EMAIL=admin@apextrader.com
ADMIN_PASSWORD=secure-admin-password

# Server
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173

# Trading Defaults
DEFAULT_FOREX_PAIRS=EURUSD=X,GBPUSD=X,USDJPY=X,XAUUSD=X
DEFAULT_CRYPTO_PAIRS=BTCUSDT,ETHUSDT
FOREX_INTERVAL_MINUTES=5
CRYPTO_INTERVAL_MINUTES=2

# Risk Settings
DEFAULT_RISK_PER_TRADE=1.0
DEFAULT_RR_RATIO=2.0
